{
  "name": "boilerplate",
  "version": "3.0.0",
  "description": "Site development template for fast and easily",
  "main": "index.js",
  "scripts": {
    "start": "yarn build",
    "clean": "gulp clean",
    "serve": "gulp --env development",
    "build": "gulp build --env development",
    "build:prod": "gulp --env production"
  },
  "author": "Hiroki Ishiwatari",
  "license": "MIT",
  "devDependencies": {
    "browser-sync": "^2.11.1",
    "del": "^3.0.0",
    "gulp": "^4.0.0",
    "gulp-if": "^2.0.0",
    "gulp-load-plugins": "^1.2.0",
    "gulp-plumber": "^1.0.1",
    "gulp-sass": "^3.1.0",
    "gulp-sourcemaps": "^2.6.0",
    "gulp-watch": "^5.0.0",
    "gutil": "^1.6.4",
    "minimist": "^1.2.0"
  },
  "dependencies": {
    "@babel/cli": "^7.0.0-beta.40",
    "@babel/core": "^7.0.0-beta.40",
    "@babel/preset-env": "^7.0.0-beta.40",
    "@babel/register": "^7.0.0-beta.40",
    "autoprefixer": "^8.1.0",
    "babel-core": "^7.0.0-bridge.0",
    "babelify": "^8.0.0",
    "css-mqpacker": "^6.0.2",
    "cssnano": "^3.10.0",
    "gulp-postcss": "^7.0.1",
    "normalize.css": "^8.0.0",
    "postcss-import": "^11.1.0",
    "webpack": "^4.1.1",
    "webpack-stream": "^4.0.2"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "browsers": [
              "last 2 versions"
            ]
          }
        }
      ]
    ]
  },
  "postcss": {
    "plugins": {
      "postcss-import": {},
      "autoprefixer": {
        "browsers": [
          "last 2 versions"
        ]
      },
      "cssnano": {},
      "css-mqpacker": {}
    }
  }
}
