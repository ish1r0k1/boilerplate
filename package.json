{
  "name": "boilerplate",
  "version": "2.0.0",
  "description": "Site development template for fast and easily",
  "main": "index.js",
  "scripts": {
    "start": "yarn build",
    "serve": "gulp --env development",
    "build": "gulp --env production"
  },
  "author": "Hiroki Ishiwatari",
  "license": "MIT",
  "devDependencies": {
    "babel-plugin-transform-object-rest-spread": "^6.23.0",
    "babel-preset-es2015": "^6.3.13",
    "browser-sync": "^2.11.1",
    "browserify": "^16.1.1",
    "del": "^3.0.0",
    "gulp": "^4.0.0",
    "gulp-babel": "^7.0.1",
    "gulp-if": "^2.0.0",
    "gulp-load-plugins": "^1.2.0",
    "gulp-plumber": "^1.0.1",
    "gulp-sass": "^3.1.0",
    "gulp-sourcemaps": "^2.6.0",
    "gulp-uglify": "^3.0.0",
    "gulp-watch": "^5.0.0",
    "gutil": "^1.6.4",
    "minimist": "^1.2.0",
    "run-sequence": "^2.2.1",
    "vinyl-buffer": "^1.0.0",
    "vinyl-source-stream": "^2.0.0",
    "watchify": "^3.9.0"
  },
  "dependencies": {
    "autoprefixer": "^8.1.0",
    "babel-core": "^6.26.0",
    "babelify": "^8.0.0",
    "css-mqpacker": "^6.0.2",
    "cssnano": "^3.10.0",
    "gulp-postcss": "^7.0.1"
  },
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {
        "browsers": [
          "last 2 versions"
        ]
      },
      "cssnano": {},
      "css-mqpacker": {}
    }
  }
}
